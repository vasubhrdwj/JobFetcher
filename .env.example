# Environment
POSTGRES_USER=vjob
POSTGRES_PASSWORD=vjob_dev
POSTGRES_DB=vjob
# For `docker compose up`, the backend gets @db from docker-compose.yml (ignore this for containers).
# For running the backend on your host (uvicorn), use localhost:
DATABASE_URL=postgresql+asyncpg://vjob:vjob_dev@localhost:5432/vjob

# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# App
APP_ENV=development
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173

# Scraping
SCRAPE_INTERVAL_HOURS=3
SCRAPE_CONCURRENCY=5